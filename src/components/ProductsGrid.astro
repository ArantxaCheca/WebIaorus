---
export interface Product {
  id: string;
  title: string;
  description: string;
  tags: string[];
  icon: string;
}

export interface Props {
  tag?: string;
  title?: string;
  subtitle?: string;
  products: Product[];
  showSectionHeader?: boolean;
}

const { tag = 'Productos', title = 'Todo lo que necesitas en un solo ecosistema', subtitle = 'Módulos inteligentes que funcionan juntos o por separado.', products, showSectionHeader = true } = Astro.props;

const icons: Record<string, string> = {
  erp: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  bp360: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  gestia: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>',
  iatask: '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  rrhh: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  accesos: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  web: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>'
};
---

<section>
  <div class="container">
    {showSectionHeader && (
      <div class="section-title">
        <span class="section-tag">{tag}</span>
        <h2>{title}</h2>
        <p>{subtitle}</p>
      </div>
    )}
    <div class="products-grid">
      {products.map(p => (
        <div class="product-card" onclick={`openProductModal('${p.id}')`}>
          <div class="product-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.icon] || icons.erp} />
          </div>
          <h3>{p.title}</h3>
          <p class="product-desc">{p.description}</p>
          <div class="product-tags">
            {p.tags.map(t => <span class="product-tag">{t}</span>)}
          </div>
          <span class="product-link">Ver documentación →</span>
          <a href={`/producto-${p.id}`} class="product-link" style="margin-left:12px;" onclick="event.stopPropagation();">▶ Ver vídeo</a>
        </div>
      ))}
    </div>
  </div>
</section>
