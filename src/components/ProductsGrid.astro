---
export interface Product {
  id: string;
  title: string;
  description: string;
  tags: string[];
  icon: string;
}

export interface Props {
  tag?: string;
  title?: string;
  subtitle?: string;
  products: Product[];
  showSectionHeader?: boolean;
}

const { tag = 'Productos', title = 'Todo lo que necesitas en un solo ecosistema', subtitle = 'Módulos inteligentes que funcionan juntos o por separado.', products, showSectionHeader = true } = Astro.props;

const images: Record<string, string> = {
  erp: '/assets/images/IAORUS ERP.jpg',
  bp360: '/assets/images/IAORUS BP360.jpg',
  gestia: '/assets/images/Gest-IA.jpg',
  iatask: '/assets/images/IATask.jpg',
  apprrhh: '/assets/images/APP RRHH.jpg',
  accesos: '/assets/images/Control de Accesos.jpg',
  web: '/assets/images/Desarrollo Web.jpg'
};
---

<section>
  <div class="container">
    {showSectionHeader && (
      <div class="section-title">
        <span class="section-tag">{tag}</span>
        <h2>{title}</h2>
        <p>{subtitle}</p>
      </div>
    )}
    <div class="products-grid">
      {products.map(p => (
        <div class="product-card" onclick={`openProductModal('${p.id}')`}>
          <div class="product-card-img">
            <img src={images[p.id] || images.erp} alt={p.title} loading="lazy" />
          </div>
          <div class="product-card-body">
            <h3>{p.title}</h3>
            <p class="product-desc">{p.description}</p>
            <div class="product-tags">
              {p.tags.map(t => <span class="product-tag">{t}</span>)}
            </div>
            <a href={`/producto-${p.id}`} class="product-link" onclick="event.stopPropagation();">▶ Ver vídeo</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
