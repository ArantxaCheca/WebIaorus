---
export interface Props {
  tag: string;
  title: string;
  subtitle: string;
  problems: { title: string; description: string }[];
  cta?: { text: string; href: string };
}

const { tag, title, subtitle, problems, cta } = Astro.props;
---

<section>
  <div class="container">
    <div class="section-title">
      <span class="section-tag">{tag}</span>
      <h2>{title}</h2>
      <p>{subtitle}</p>
    </div>
    <div class="problems-grid">
      {problems.map(p => (
        <div class="problem-card">
          <h4>{p.title}</h4>
          <p>{p.description}</p>
        </div>
      ))}
    </div>
    {cta && (
      <div style="text-align:center;margin-top:32px;">
        <a href={cta.href} class="btn btn-orange">{cta.text}</a>
      </div>
    )}
  </div>
</section>
