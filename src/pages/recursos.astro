---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'Recursos Documentales - IAORUS';
const description = 'Repositorio documental IAORUS: catálogos, presentaciones, fichas técnicas, casos de uso y documentación comercial.';
const currentPage = '/recursos';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="page-header">
  <div class="container">
    <h1>Repositorio Documental</h1>
    <p>Accede a toda la documentación corporativa: catálogos, presentaciones, fichas funcionales, documentos técnicos y comerciales.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="filter-bar">
      <button class="filter-btn active" onclick="filterResources('all')">Todos</button>
      <button class="filter-btn" onclick="filterResources('comercial')">Catálogos</button>
      <button class="filter-btn" onclick="filterResources('presentacion')">Presentaciones</button>
      <button class="filter-btn" onclick="filterResources('funcional')">Fichas Funcionales</button>
      <button class="filter-btn" onclick="filterResources('tecnico')">Documentación Técnica</button>
      <button class="filter-btn" onclick="filterResources('comercial-doc')">Comerciales</button>
      <a href="/recursos-audiovisuales" class="filter-btn" style="background:var(--orange);color:var(--white);border-color:var(--orange);">▶ Vídeos</a>
    </div>
    <div class="resources-grid">
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo IAORUS ERP</h4>
        <p>Catálogo comercial completo del ERP IAORUS con módulos y funcionalidades.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo IAORUS BP360</h4>
        <p>Plataforma inmobiliaria inteligente: activos, inversores y colaboradores.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo Gest-IA</h4>
        <p>Gestión inteligente de documentos y expedientes con IA.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo IATask</h4>
        <p>Optimización de producción y control de asistencia.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo APP RRHH</h4>
        <p>Tests y evaluación de talento con IA y metodología científica.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h4>Catálogo Desarrollo Web</h4>
        <p>Páginas web corporativas y tiendas online a medida.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="presentacion">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h4>Presentación Corporativa 2025</h4>
        <p>Presentación institucional de IAORUS y su propuesta de valor.</p>
        <span class="resource-count">Presentación</span>
      </div>
      <div class="resource-card" data-category="presentacion">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h4>Presentación BP360 PROMO</h4>
        <p>Presentación comercial de IAORUS BP360 para sector inmobiliario.</p>
        <span class="resource-count">Presentación</span>
      </div>
      <div class="resource-card" data-category="presentacion">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h4>Presentación Comercial ERP</h4>
        <p>Presentación técnica-comercial del ERP IAORUS.</p>
        <span class="resource-count">Presentación</span>
      </div>
      <div class="resource-card" data-category="presentacion">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h4>Presentación Control de Presencia</h4>
        <p>Solución de control de presencia platform.</p>
        <span class="resource-count">Presentación</span>
      </div>
      <div class="resource-card" data-category="funcional">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
        <h4>Ficha Funcional ERP</h4>
        <p>Descripción funcional detallada del ERP IAORUS y sus módulos.</p>
        <span class="resource-count">Funcional</span>
      </div>
      <div class="resource-card" data-category="funcional">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
        <h4>Ficha Funcional BP360</h4>
        <p>Funcionalidades detalladas de la plataforma inmobiliaria.</p>
        <span class="resource-count">Funcional</span>
      </div>
      <div class="resource-card" data-category="funcional">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
        <h4>Casos de Uso ERP</h4>
        <p>Escenarios de uso del ERP IAORUS por sector y tamaño.</p>
        <span class="resource-count">Funcional</span>
      </div>
      <div class="resource-card" data-category="funcional">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
        <h4>Metodología de Desarrollo</h4>
        <p>Proceso de desarrollo a medida de IAORUS: fases y entregables.</p>
        <span class="resource-count">Funcional</span>
      </div>
      <div class="resource-card" data-category="tecnico">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
        <h4>Arquitectura del Sistema</h4>
        <p>Gestión documental y ERP para organizaciones. Arquitectura técnica.</p>
        <span class="resource-count">Técnico</span>
      </div>
      <div class="resource-card" data-category="tecnico">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
        <h4>Documentación API REST</h4>
        <p>API completa para integración con sistemas externos.</p>
        <span class="resource-count">Técnico</span>
      </div>
      <div class="resource-card" data-category="tecnico">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
        <h4>Guía de Seguridad</h4>
        <p>Cifrado, roles, auditoría y cumplimiento RGPD.</p>
        <span class="resource-count">Técnico</span>
      </div>
      <div class="resource-card" data-category="comercial-doc">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
        <h4>Documento ROI ERP</h4>
        <p>Análisis de retorno de inversión para implantación de IAORUS ERP.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial-doc">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
        <h4>Documento ROI BP360</h4>
        <p>ROI de la plataforma inmobiliaria IAORUS BP360.</p>
        <span class="resource-count">Comercial</span>
      </div>
      <div class="resource-card" data-category="comercial-doc">
        <div class="resource-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
        <h4>Estudio de Mercado Servicios</h4>
        <p>Análisis del mercado de software para empresas de servicios en España.</p>
        <span class="resource-count">Estudio</span>
      </div>
    </div>
  </div>
</section>

<section class="testimonials">
  <div class="container">
    <span class="section-tag">Testimonios</span>
    <h2>Lo que dicen nuestros clientes</h2>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p>"IAORUS ha transformado nuestra gestión documental. Ahora todo está centralizado y accesible en tiempo real."</p>
        <div class="testimonial-author">
          <strong>Carlos Méndez</strong>
          <span>Director de Operaciones, Grupo Logis</span>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p>"La implementación del ERP fue rápida y el soporte excepcional. Recomendamos IAORUS sin reservas."</p>
        <div class="testimonial-author">
          <strong>Ana Beltrán</strong>
          <span>CEO, Inmobiliaria Norte</span>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p>"La documentación técnica y los casos de uso nos ayudaron a tomar la mejor decisión para nuestra empresa."</p>
        <div class="testimonial-author">
          <strong>Miguel Ángel Ruiz</strong>
          <span>CTO, TechSolutions</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-light" style="text-align:center;">
  <div class="container">
    <span class="section-tag">¿Necesitas más?</span>
    <h2>¿Buscas documentación específica?</h2>
    <p style="max-width:500px;margin:0 auto 24px;">Si necesitas algún documento que no encuentres aquí, solicítanoslo y te lo haremos llegar.</p>
    <a href="/contacto" class="btn btn-demo">Solicitar Documentación</a>
  </div>
</section>

  <Footer slot="footer" />
</BaseLayout>
