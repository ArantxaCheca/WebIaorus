---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Recursos Documentales - IAORUS';
const description = 'Repositorio documental IAORUS: catálogos, presentaciones, fichas técnicas, casos de uso y documentación comercial.';
const currentPage = '/recursos';
const resources = [
  { category: 'comercial', name: 'Catálogo IAORUS ERP', desc: 'Catálogo comercial completo del ERP IAORUS con módulos y funcionalidades.' },
  { category: 'comercial', name: 'Catálogo IAORUS BP360', desc: 'Plataforma inmobiliaria inteligente: activos, inversores y colaboradores.' },
  { category: 'comercial', name: 'Catálogo Gest-IA', desc: 'Gestión inteligente de documentos y expedientes con IA.' },
  { category: 'comercial', name: 'Catálogo IATask', desc: 'Optimización de producción y control de asistencia.' },
  { category: 'comercial', name: 'Catálogo APP RRHH', desc: 'Tests y evaluación de talento con IA y metodología científica.' },
  { category: 'comercial', name: 'Catálogo Desarrollo Web', desc: 'Páginas web corporativas y tiendas online a medida.' },
  { category: 'presentacion', name: 'Presentación Corporativa 2025', desc: 'Presentación institucional de IAORUS y su propuesta de valor.' },
  { category: 'presentacion', name: 'Presentación BP360 PROMO', desc: 'Presentación comercial de IAORUS BP360 para sector inmobiliario.' },
  { category: 'presentacion', name: 'Presentación Comercial ERP', desc: 'Presentación técnica-comercial del ERP IAORUS.' },
  { category: 'presentacion', name: 'Presentación Control de Presencia', desc: 'Solución de control de presencia platform.' },
  { category: 'funcional', name: 'Ficha Funcional ERP', desc: 'Descripción funcional detallada del ERP IAORUS y sus módulos.' },
  { category: 'funcional', name: 'Ficha Funcional BP360', desc: 'Funcionalidades detalladas de la plataforma inmobiliaria.' },
  { category: 'funcional', name: 'Casos de Uso ERP', desc: 'Escenarios de uso del ERP IAORUS por sector y tamaño.' },
  { category: 'funcional', name: 'Metodología de Desarrollo', desc: 'Proceso de desarrollo a medida de IAORUS: fases y entregables.' },
  { category: 'tecnico', name: 'Arquitectura del Sistema', desc: 'Gestión documental y ERP para organizaciones. Arquitectura técnica.' },
  { category: 'tecnico', name: 'Documentación API REST', desc: 'API completa para integración con sistemas externos.' },
  { category: 'tecnico', name: 'Guía de Seguridad', desc: 'Cifrado, roles, auditoría y cumplimiento RGPD.' },
  { category: 'comercial-doc', name: 'Documento ROI ERP', desc: 'Análisis de retorno de inversión para implantación de IAORUS ERP.' },
  { category: 'comercial-doc', name: 'Documento ROI BP360', desc: 'ROI de la plataforma inmobiliaria IAORUS BP360.' },
  { category: 'comercial-doc', name: 'Estudio de Mercado Servicios', desc: 'Análisis del mercado de software para empresas de servicios en España.' }
];
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="page-header">
    <div class="container">
      <h1>Repositorio Documental</h1>
      <p>Accede a toda la documentación corporativa: catálogos, presentaciones, fichas funcionales, documentos técnicos y comerciales.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="filter-bar">
        <button class="filter-btn active" onclick="filterResources('all')">Todos</button>
        <button class="filter-btn" onclick="filterResources('comercial')">Catálogos</button>
        <button class="filter-btn" onclick="filterResources('presentacion')">Presentaciones</button>
        <button class="filter-btn" onclick="filterResources('funcional')">Fichas Funcionales</button>
        <button class="filter-btn" onclick="filterResources('tecnico')">Documentación Técnica</button>
        <button class="filter-btn" onclick="filterResources('comercial-doc')">Comerciales</button>
        <a href="/recursos-audiovisuales" class="filter-btn" style="background:var(--orange);color:var(--white);border-color:var(--orange);">▶ Vídeos</a>
      </div>
      <div class="resources-grid">
        {resources.map(r => (
          <div class="resource-card" data-category={r.category}>
            <div class="resource-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <h4>{r.name}</h4>
            <p>{r.desc}</p>
            <span class="resource-count">{r.category === 'comercial' ? 'Comercial' : r.category === 'presentacion' ? 'Presentación' : r.category === 'funcional' ? 'Funcional' : r.category === 'tecnico' ? 'Técnico' : 'Comercial'}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--gray-bg);">
    <div class="container">
      <div class="section-title">
        <span class="section-tag">Testimonios</span>
        <h2>Lo que dicen nuestros clientes</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;">
        <div style="background:var(--white);border-radius:var(--radius);padding:28px;box-shadow:var(--shadow);border:1px solid var(--border);">
          <div style="color:var(--orange);margin-bottom:12px;font-size:1.1rem;">★★★★★</div>
          <p style="font-size:0.9rem;color:var(--gray);font-style:italic;">"IAORUS ha transformado nuestra gestión documental. Ahora todo está centralizado y accesible en tiempo real."</p>
          <div style="margin-top:16px;">
            <strong style="color:var(--blue-dark);display:block;">Carlos Méndez</strong>
            <span style="font-size:0.8rem;color:var(--gray-light);">Director de Operaciones, Grupo Logis</span>
          </div>
        </div>
        <div style="background:var(--white);border-radius:var(--radius);padding:28px;box-shadow:var(--shadow);border:1px solid var(--border);">
          <div style="color:var(--orange);margin-bottom:12px;font-size:1.1rem;">★★★★★</div>
          <p style="font-size:0.9rem;color:var(--gray);font-style:italic;">"La implementación del ERP fue rápida y el soporte excepcional. Recomendamos IAORUS sin reservas."</p>
          <div style="margin-top:16px;">
            <strong style="color:var(--blue-dark);display:block;">Ana Beltrán</strong>
            <span style="font-size:0.8rem;color:var(--gray-light);">CEO, Inmobiliaria Norte</span>
          </div>
        </div>
        <div style="background:var(--white);border-radius:var(--radius);padding:28px;box-shadow:var(--shadow);border:1px solid var(--border);">
          <div style="color:var(--orange);margin-bottom:12px;font-size:1.1rem;">★★★★★</div>
          <p style="font-size:0.9rem;color:var(--gray);font-style:italic;">"La documentación técnica y los casos de uso nos ayudaron a tomar la mejor decisión para nuestra empresa."</p>
          <div style="margin-top:16px;">
            <strong style="color:var(--blue-dark);display:block;">Miguel Ángel Ruiz</strong>
            <span style="font-size:0.8rem;color:var(--gray-light);">CTO, TechSolutions</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light" style="text-align:center;">
    <div class="container">
      <span class="section-tag">¿Necesitas más?</span>
      <h2>¿Buscas documentación específica?</h2>
      <p style="max-width:500px;margin:0 auto 24px;">Si necesitas algún documento que no encuentres aquí, solicítanoslo y te lo haremos llegar.</p>
      <a href="/contacto" class="btn btn-demo">Solicitar Documentación</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
