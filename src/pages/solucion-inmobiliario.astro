---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'IAORUS Inmobiliario - Gestión de Activos';
const description = 'Plataforma que centraliza activos, inversores y colaboradores del sector inmobiliario.';
const currentPage = '/solucion-inmobiliario';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
  <div class="video-hero-bg"></div>
  <div class="container">
    <div class="video-hero-content">
      <div class="video-hero-text">
        <span class="hero-tag" style="background:rgba(244,121,32,0.2);border-color:rgba(244,121,32,0.3);">Solución / Inmobiliario</span>
        <h1>IAORUS Inmobiliario</h1>
        <p>Profesionaliza tu negocio inmobiliario. Centraliza activos, inversores y colaboradores en un solo entorno digital.</p>
        <div class="hero-actions" style="justify-content:flex-start;">
          <a href="/demo?producto=inmobiliario" class="btn btn-demo btn-lg">Solicitar demo Inmobiliario →</a>
          <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
        </div>
      </div>
      <div class="video-thumb-wrapper" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_INMOBILIARIO', 'IAORUS Inmobiliario')">
        <img src="/assets/images/thumbnails/thumb-inmobiliario.jpg" alt="IAORUS Inmobiliario" onerror="imgFallback(this,'INM')">
        <div class="video-thumb-overlay">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-title">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
      <h2>¿Qué consigues con IAORUS Inmobiliario?</h2>
    </div>
    <div class="landing-benefits">
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Activos centralizados</h4>
        <p>Toda tu cartera y documentación en un solo lugar</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Red de colaboradores</h4>
        <p>Trabaja en red con agentes, tasadores y gestores</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Gestión de inversores</h4>
        <p>Reporting profesional y transparencia total</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Procesos ágiles</h4>
        <p>Acelera tus operaciones comerciales</p>
      </div>
    </div>
  </div>
</section>

<section class="bg-gray">
  <div class="container">
    <div class="section-title">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
      <h2>Implementación en 3 pasos</h2>
    </div>
    <div class="landing-steps">
      <div class="landing-step">
        <div class="landing-step-num">1</div>
        <h4>Centralizamos activos</h4>
        <p>Cargamos tu cartera y documentación</p>
      </div>
      <div class="landing-step">
        <div class="landing-step-num">2</div>
        <h4>Conectamos tu red</h4>
        <p>Damos acceso personalizado a colaboradores e inversores</p>
      </div>
      <div class="landing-step">
        <div class="landing-step-num">3</div>
        <h4>Escalas tu negocio</h4>
        <p>Opera con la profesionalidad de una gran gestora</p>
      </div>
    </div>
  </div>
</section>

<section class="landing-cta-section">
  <div class="container">
    <h2>Profesionaliza tu negocio inmobiliario</h2>
    <p>Descubre cómo IAORUS Inmobiliario puede ayudarte a centralizar activos y escalar tu operación.</p>
    <div class="landing-cta-actions">
      <a href="/demo?producto=inmobiliario" class="btn btn-demo btn-lg">Solicitar demo Inmobiliario →</a>
      <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
    </div>
  </div>
</section>

  <Footer slot="footer" />
</BaseLayout>
