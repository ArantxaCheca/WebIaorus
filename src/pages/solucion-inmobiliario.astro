---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'IAORUS Inmobiliario - Gestión de Activos';
const description = 'Plataforma que centraliza activos, inversores y colaboradores del sector inmobiliario.';
const currentPage = '/solucion-inmobiliario';
const productKey = 'inmobiliario';
const productTag = 'Inmobiliario';
const productTitle = 'IAORUS Inmobiliario';
const productDesc = 'Profesionaliza tu negocio inmobiliario. Centraliza activos, inversores y colaboradores en un solo entorno digital.';
const videoUrl = 'https://www.youtube.com/embed/VIDEO_ID_INMOBILIARIO';
const thumb = 'thumb-inmobiliario';
const thumbFallback = 'INM';
const benefits = [
  { title: 'Activos centralizados', desc: 'Toda tu cartera y documentación en un solo lugar' },
  { title: 'Red de colaboradores', desc: 'Trabaja en red con agentes, tasadores y gestores' },
  { title: 'Gestión de inversores', desc: 'Reporting profesional y transparencia total' },
  { title: 'Procesos ágiles', desc: 'Acelera tus operaciones comerciales' }
];
const steps = [
  { number: '1', title: 'Centralizamos activos', description: 'Cargamos tu cartera y documentación' },
  { number: '2', title: 'Conectamos tu red', description: 'Damos acceso personalizado a colaboradores e inversores' },
  { number: '3', title: 'Escalas tu negocio', description: 'Opera con la profesionalidad de una gran gestora' }
];
const demoHref = `/demo?producto=${productKey}`;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag" style="background:rgba(244,121,32,0.2);border-color:rgba(244,121,32,0.3);">Solución / {productTag}</span>
          <h1>{productTitle}</h1>
          <p>{productDesc}</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href={demoHref} class="btn btn-demo btn-lg">Solicitar demo {productTag} →</a>
            <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick={`openVideo('${videoUrl}', '${productTitle}')`}>
          <img src={`/assets/images/thumbnails/${thumb}.jpg`} alt={productTitle} onerror={`imgFallback(this,'${thumbFallback}')`}>
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2>¿Qué consigues con {productTitle}?</h2>
      </div>
      <div class="landing-benefits">
        {benefits.map(b => (
          <div class="landing-benefit">
            <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>Implementación en 3 pasos</h2>
      </div>
      <div class="landing-steps">
        {steps.map(s => (
          <div class="landing-step">
            <div class="landing-step-num">{s.number}</div>
            <h4>{s.title}</h4>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title={`Profesionaliza tu negocio ${productTag.toLowerCase()}`}
    subtitle={`Descubre cómo ${productTitle} puede ayudarte a centralizar activos y escalar tu operación.`}
    ctaPrimary={{ text: `Solicitar demo ${productTag} →`, href: demoHref }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
    variant="landing-cta-section"
  />

  <Footer slot="footer" />
</BaseLayout>
