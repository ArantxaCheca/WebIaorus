---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'APP RRHH - Evaluación de Talento con IA';
const description = 'Tests, cuestionarios e informes para contratar, formar y retener el mejor equipo con inteligencia artificial.';
const currentPage = '/producto-apprrhh';
const p = { key: 'apprrhh', tag: 'Producto', name: 'APP RRHH', desc: 'Encuentra y retén el mejor talento. Tests, evaluaciones e informes con inteligencia artificial para tomar decisiones informadas sobre tu equipo.', video: 'VIDEO_ID_APRRHH', thumb: 'thumb-apprrhh', fb: 'RH', img: 'pexels-kampus-8353815.jpg' };
const features = [
  { title: 'Tests de talento', desc: 'Evaluaciones psicométricas y de competencias' },
  { title: 'Informes IA', desc: 'Análisis automático de resultados' },
  { title: 'Benchmarking', desc: 'Comparativa con perfiles de éxito' },
  { title: 'Retención', desc: 'Identifica riesgos de fuga de talento' }
];
const benefits = [
  { title: 'Contrataciones acertadas', desc: 'Selecciona el candidato ideal con datos objetivos' },
  { title: 'Desarrollo del talento', desc: 'Identifica áreas de mejora en tu equipo' },
  { title: 'Ahorro de tiempo', desc: 'Automatiza el proceso de evaluación' },
  { title: 'Decisiones objetivas', desc: 'Basadas en datos, no en corazonadas' }
];
const steps = [
  { number: '1', title: 'Configuramos', description: 'Definimos los perfiles y competencias a evaluar' },
  { number: '2', title: 'Evaluamos', description: 'Los candidatos realizan tests adaptativos' },
  { number: '3', title: 'Decidimos', description: 'Recibes informes con recomendaciones de IA' }
];
const demoHref = `/demo?producto=${p.key}`;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag">Producto</span>
          <h1>{p.name}</h1>
          <p>{p.desc}</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href={demoHref} class="btn btn-demo">Solicitar demo gratuita →</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick={`openVideo('https://www.youtube.com/embed/${p.video}', '${p.name}')`}>
          <img src={`/assets/images/thumbnails/${p.thumb}.jpg`} alt={p.name} onerror={`imgFallback(this,'${p.fb}')`}>
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="split-grid">
        <div>
          <img src={`/assets/images/${p.img}`} alt={`Panel ${p.name}`} class="img-section">
        </div>
        <div>
          <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Características</span>
          <h2>Características principales</h2>
          <div class="landing-benefits" style="grid-template-columns:1fr 1fr;">
            {features.map(f => (
              <div class="landing-benefit">
                <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
                <h4>{f.title}</h4>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2>¿Por qué {p.name}?</h2>
      </div>
      <div class="landing-benefits">
        {benefits.map(b => (
          <div class="landing-benefit">
            <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Vídeo</span>
        <h2>Vídeo demostrativo</h2>
        <p>Descubre cómo funciona {p.name} en la práctica.</p>
      </div>
      <div class="video-placeholder">
        <div class="vp-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        <p class="vp-text">Vídeo demostrativo disponible próximamente</p>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>Tu evaluación de talento en 3 pasos</h2>
        <p>Te acompañamos en cada etapa para una transición sin fricción.</p>
      </div>
      <div class="landing-steps">
        {steps.map(s => (
          <div class="landing-step">
            <div class="landing-step-num">{s.number}</div>
            <h4>{s.title}</h4>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title="¿Listo para encontrar el mejor talento?"
    subtitle={`Solicita una demo personalizada y descubre cómo ${p.name} puede transformar tu selección de personal.`}
    ctaPrimary={{ text: 'Solicitar demo gratuita →', href: demoHref }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
    variant="landing-cta-section"
  />

  <CtaBlock
    variant="floating"
    title="¿Listo para transformar tu negocio?"
    ctaPrimary={{ text: 'Solicitar demo →', href: demoHref }}
    ctaSecondary={{ text: 'Contactar', href: '/contacto' }}
  />

  <Footer slot="footer" />
</BaseLayout>
