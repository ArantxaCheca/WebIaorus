---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'APP RRHH - Evaluación de Talento con IA';
const description = 'Evaluación del talento con IA. Tests, cuestionarios e informes para contratar, formar y retener el mejor equipo.';
const currentPage = '/producto-apprrhh';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />
  
  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag">Producto</span>
          <h1>APP RRHH</h1>
          <p>Encuentra y retén el mejor talento. Tests, evaluaciones e informes con inteligencia artificial para tomar decisiones informadas sobre tu equipo.</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href="/demo?producto=rrhh" class="btn btn-demo">Solicitar demo APP RRHH →</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_APRRHH', 'APP RRHH')">
          <img src="/assets/images/thumbnails/thumb-apprrhh.jpg" alt="APP RRHH" onerror="imgFallback(this,'RH')">
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="split-grid">
        <div>
          <img src="/assets/images/pexels-vlada-karpovich-7433883.jpg" alt="Panel APP RRHH" class="img-section">
        </div>
        <div>
          <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Características</span>
          <h2>Características principales</h2>
          <div class="landing-benefits" style="grid-template-columns:1fr 1fr;">
            <div class="landing-benefit">
              <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
              <h4>Evaluación objetiva</h4>
              <p>Pruebas psicométricas y técnicas integradas</p>
            </div>
            <div class="landing-benefit">
              <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
              <h4>Pipeline de selección</h4>
              <p>Gestiona todo el proceso de contratación</p>
            </div>
            <div class="landing-benefit">
              <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
              <h4>Perfiles IA</h4>
              <p>Match automático entre candidatos y puestos</p>
            </div>
            <div class="landing-benefit">
              <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
              <h4>Reportes analíticos</h4>
              <p>Datos para decisiones de talento informadas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2>¿Por qué APP RRHH?</h2>
        <p>Toma decisiones de talento basadas en datos, no en intuición.</p>
      </div>
      <div class="landing-benefits">
        <div class="landing-benefit">
          <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
          <h4>Selección objetiva</h4>
          <p>Evaluaciones basadas en datos, no en intuición</p>
        </div>
        <div class="landing-benefit">
          <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
          <h4>Ahorro de tiempo</h4>
          <p>Reduce hasta un 50% el tiempo de selección</p>
        </div>
        <div class="landing-benefit">
          <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
          <h4>Desarrollo del talento</h4>
          <p>Identifica el potencial de cada miembro del equipo</p>
        </div>
        <div class="landing-benefit">
          <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
          <h4>Retención inteligente</h4>
          <p>Conoce qué motiva a tu equipo y reduce la rotación</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Vídeo</span>
        <h2>Vídeo demostrativo</h2>
        <p>Descubre cómo funciona APP RRHH en la práctica.</p>
      </div>
      <div class="video-placeholder">
        <div class="vp-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        <p class="vp-text">Vídeo demostrativo disponible próximamente</p>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>APP RRHH en 3 pasos</h2>
        <p>Implementación sencilla para transformar tu gestión de talento.</p>
      </div>
      <div class="landing-steps">
        <div class="landing-step">
          <div class="landing-step-num">1</div>
          <h4>Definimos perfiles</h4>
          <p>Configuramos las competencias y habilidades clave</p>
        </div>
        <div class="landing-step">
          <div class="landing-step-num">2</div>
          <h4>Evaluamos con IA</h4>
          <p>Tests y cuestionarios automatizados con análisis inteligente</p>
        </div>
        <div class="landing-step">
          <div class="landing-step-num">3</div>
          <h4>Decisiones informadas</h4>
          <p>Informes detallados para contratar, formar y retener</p>
        </div>
      </div>
    </div>
  </section>

  <section class="landing-cta-section">
    <div class="container">
      <h2>¿Listo para transformar tu gestión de talento?</h2>
      <p>Solicita una demo personalizada y descubre cómo APP RRHH puede impulsar tu equipo.</p>
      <div class="landing-cta-actions">
        <a href="/demo?producto=rrhh" class="btn btn-demo">Solicitar demo APP RRHH →</a>
        <a href="/contacto" class="btn btn-outline-orange">Hablar con un especialista</a>
      </div>
    </div>
  </section>

  <div class="cta-floating">
    <div class="container">
      <p>¿Listo para transformar tu gestión de talento?</p>
      <div style="display:flex;gap:8px;">
        <a href="/demo?producto=rrhh" class="btn btn-demo btn-sm">Solicitar demo →</a>
        <a href="/contacto" class="btn btn-outline-orange btn-sm">Contactar</a>
      </div>
    </div>
  </div>
  
  <Footer slot="footer" />
</BaseLayout>
