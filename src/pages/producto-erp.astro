---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'IAORUS ERP - Gestiona todo desde una única plataforma';
const description = 'Gestiona tu empresa desde una sola plataforma: ventas, compras, clientes, finanzas, RRHH, proyectos y más.';
const currentPage = '/producto-erp';
const p = { key: 'erp', tag: 'Producto', name: 'IAORUS ERP', desc: 'Gestiona ventas, compras, clientes, finanzas y operaciones desde una única plataforma.', video: 'VIDEO_ID_ERP', thumb: 'thumb-erp', fb: 'ERP', img: 'pexels-kampus-8353815.jpg' };
const benefits = [
  { title: 'Integración total', desc: 'Todos tus departamentos conectados en una sola plataforma' },
  { title: 'Datos en tiempo real', desc: 'Toma decisiones con información actualizada al instante' },
  { title: 'Automatización inteligente', desc: 'Reduce tareas manuales hasta un 70%' },
  { title: 'Escalabilidad real', desc: 'Crece sin límites, la plataforma se adapta a ti' }
];
const steps = [
  { number: '1', title: 'Analizamos tu empresa', description: 'Identificamos procesos, necesidades y áreas de mejora.' },
  { number: '2', title: 'Configuramos la plataforma', description: 'Adaptamos IAORUS ERP a la forma de trabajar de tu equipo.' },
  { number: '3', title: 'Empiezas a trabajar con IAORUS', description: 'Tu empresa comienza a gestionar sus procesos desde un entorno más conectado y eficiente.' }
];
const demoHref = `/demo?producto=${p.key}`;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag">Producto</span>
          <h1>{p.name}</h1>
          <p>{p.desc}</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href={demoHref} class="btn btn-demo">Solicitar demo gratuita →</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick={`openVideo('https://www.youtube.com/embed/${p.video}', '${p.name}')`}>
          <img src={`/assets/images/thumbnails/${p.thumb}.jpg`} alt={p.name} onerror={`imgFallback(this,'${p.fb}')`}>
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="split-grid split-grid--tight">
        <div>
          <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Plataforma</span>
          <h2 style="margin-bottom:12px;">Gestiona todo desde una única plataforma</h2>
          <p style="margin-bottom:24px;">IAORUS ERP centraliza las áreas clave de tu empresa para que puedas trabajar con información conectada, procesos más ágiles y una visión global del negocio.</p>
          <div class="module-grid">
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Ventas</h4><p>Gestión comercial y facturación.</p></div></div>
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Compras</h4><p>Proveedores, pedidos y stock.</p></div></div>
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Clientes</h4><p>CRM y seguimiento comercial.</p></div></div>
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Finanzas</h4><p>Contabilidad, tesorería y reportes.</p></div></div>
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>RRHH</h4><p>Empleados, nóminas y talento.</p></div></div>
            <div class="module-card"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Proyectos</h4><p>Planificación y seguimiento.</p></div></div>
            <div class="module-card module-card-full"><div class="module-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="module-card-body"><h4>Documentación</h4><p>Gestión documental integrada.</p></div></div>
          </div>
        </div>
        <div>
          <img src="/assets/images/p1img1.jpg" alt="Panel IAORUS ERP" class="img-section">
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray section--tight">
    <div class="container">
      <div class="section-title" style="margin-bottom:32px;">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2 style="margin-bottom:8px;">Menos herramientas. Más control.</h2>
        <p>Centraliza procesos, conecta equipos y reduce tareas manuales con una solución diseñada para adaptarse a tu empresa.</p>
      </div>
      <div class="landing-benefits">
        {benefits.map(b => (
          <div class="landing-benefit">
            <div class="landing-benefit-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Vídeo</span>
        <h2>Descubre IAORUS ERP en menos de 90 segundos</h2>
        <p>Mira cómo centralizar procesos, automatizar tareas y mejorar la productividad de tu empresa desde una única plataforma.</p>
      </div>
      <div class="video-placeholder">
        <div class="vp-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        <p class="vp-text">Vídeo demostrativo disponible próximamente</p>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>Tu nuevo ERP en 3 pasos</h2>
        <p>Te acompañamos en cada etapa para una transición sin fricción.</p>
      </div>
      <div class="landing-steps">
        {steps.map(s => (
          <div class="landing-step">
            <div class="landing-step-num">{s.number}</div>
            <h4>{s.title}</h4>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title="¿Listo para transformar la gestión de tu empresa?"
    subtitle="Solicita una demo personalizada y descubre cómo IAORUS ERP puede ayudarte a centralizar procesos, ahorrar tiempo y mejorar la toma de decisiones."
    ctaPrimary={{ text: 'Solicitar demo gratuita', href: demoHref }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
    variant="landing-cta-section"
  />

  <CtaBlock
    variant="floating"
    title="¿Listo para transformar la gestión de tu empresa?"
    ctaPrimary={{ text: 'Solicitar demo gratuita', href: demoHref }}
    ctaSecondary={{ text: 'Contactar', href: '/contacto' }}
  />

  <Footer slot="footer" />
</BaseLayout>
