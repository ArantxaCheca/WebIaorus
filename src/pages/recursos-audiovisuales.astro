---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Vídeos - IAORUS';
const description = 'Biblioteca de vídeos corporativos, demostraciones de productos y soluciones por sector IAORUS.';
const currentPage = '/recursos-audiovisuales';
const videos = [
  { category: 'producto', videoId: 'VIDEO_ID_ERP', title: 'IAORUS ERP', desc: 'El centro de operaciones de tu empresa. Gestión integral con inteligencia de negocio.', thumb: 'thumb-erp', fallback: 'ERP' },
  { category: 'producto', videoId: 'VIDEO_ID_BP360', title: 'IAORUS BP360', desc: 'Plataforma inteligente para el sector inmobiliario con IA integrada.', thumb: 'thumb-bp360', fallback: 'BP' },
  { category: 'producto', videoId: 'VIDEO_ID_GESTIA', title: 'Gest-IA', desc: 'Gestión inteligente de documentos y expedientes con inteligencia artificial.', thumb: 'thumb-gestia', fallback: 'GI' },
  { category: 'producto', videoId: 'VIDEO_ID_IATASK', title: 'IATask', desc: 'Control de producción, tareas y asistencia en una plataforma unificada.', thumb: 'thumb-iatask', fallback: 'IT' },
  { category: 'producto', videoId: 'VIDEO_ID_APRRHH', title: 'APP RRHH', desc: 'Evaluación de talento con IA y metodología científica.', thumb: 'thumb-apprrhh', fallback: 'RH' },
  { category: 'producto', videoId: 'VIDEO_ID_ACCESOS', title: 'Control de Accesos', desc: 'Control de accesos inteligente con RFID, biometría y QR.', thumb: 'thumb-accesos', fallback: 'CA' },
  { category: 'producto', videoId: 'VIDEO_ID_WEB', title: 'Desarrollo Web', desc: 'Páginas web corporativas y tiendas online a medida.', thumb: 'thumb-web', fallback: 'DW' },
  { category: 'solucion', videoId: 'VIDEO_ID_INDUSTRIAL', title: 'Industrial', desc: 'Solución para la gestión industrial y optimización de procesos productivos.', thumb: 'thumb-industrial', fallback: 'IND' },
  { category: 'solucion', videoId: 'VIDEO_ID_RETAIL', title: 'Retail', desc: 'Gestión comercial inteligente para tiendas y canales online.', thumb: 'thumb-retail', fallback: 'RET' },
  { category: 'solucion', videoId: 'VIDEO_ID_SERVICIOS', title: 'Servicios Profesionales', desc: 'Control de proyectos, facturación y rentabilidad para consultoras.', thumb: 'thumb-servicios', fallback: 'SP' },
  { category: 'solucion', videoId: 'VIDEO_ID_INMOBILIARIO', title: 'Inmobiliario', desc: 'Centraliza activos, inversores y colaboradores del sector inmobiliario.', thumb: 'thumb-inmobiliario', fallback: 'INM' }
];
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-page-header">
    <div class="container">
      <h1>Recursos Audiovisuales</h1>
      <p>Biblioteca de vídeos corporativos. Conoce nuestros productos y soluciones en acción.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="filter-bar">
        <button class="filter-btn active" onclick="filterResources('all')">Todos</button>
        <button class="filter-btn" onclick="filterResources('producto')">Productos</button>
        <button class="filter-btn" onclick="filterResources('solucion')">Soluciones</button>
      </div>
      <div class="video-cards-grid">
        {videos.map(v => (
          <div class="video-card" data-category={v.category} onclick={`openVideo('https://www.youtube.com/embed/${v.videoId}', '${v.title}')`}>
            <div class="video-card-thumb">
              <img src={`/assets/images/thumbnails/${v.thumb}.jpg`} alt={v.title} loading="lazy" onerror={`imgFallback(this,'${v.fallback}')`}>
              <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
            </div>
            <div class="video-card-body">
              <span class="video-card-tag">{v.category === 'producto' ? 'Producto' : 'Solución'}</span>
              <h3>{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
