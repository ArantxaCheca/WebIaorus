---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'Vídeos - IAORUS';
const description = 'Biblioteca de vídeos corporativos, demostraciones de productos y soluciones por sector IAORUS.';
const currentPage = '/recursos-audiovisuales';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-page-header">
  <div class="container">
    <h1>Recursos Audiovisuales</h1>
    <p>Biblioteca de vídeos corporativos. Conoce nuestros productos y soluciones en acción.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="filter-bar">
      <button class="filter-btn active" onclick="filterVideos('all')">Todos</button>
      <button class="filter-btn" onclick="filterVideos('producto')">Productos</button>
      <button class="filter-btn" onclick="filterVideos('solucion')">Soluciones</button>
    </div>
    <div class="video-cards-grid">
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_ERP', 'IAORUS ERP')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-erp.jpg" alt="IAORUS ERP" loading="lazy" onerror="imgFallback(this,'ERP')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>IAORUS ERP</h3>
          <p>El centro de operaciones de tu empresa. Gestión integral con inteligencia de negocio.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_BP360', 'IAORUS BP360')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-bp360.jpg" alt="IAORUS BP360" loading="lazy" onerror="imgFallback(this,'BP')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>IAORUS BP360</h3>
          <p>Plataforma inteligente para el sector inmobiliario con IA integrada.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_GESTIA', 'Gest-IA')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-gestia.jpg" alt="Gest-IA" loading="lazy" onerror="imgFallback(this,'GI')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>Gest-IA</h3>
          <p>Gestión inteligente de documentos y expedientes con inteligencia artificial.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_IATASK', 'IATask')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-iatask.jpg" alt="IATask" loading="lazy" onerror="imgFallback(this,'IT')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>IATask</h3>
          <p>Control de producción, tareas y asistencia en una plataforma unificada.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_APRRHH', 'APP RRHH')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-apprrhh.jpg" alt="APP RRHH" loading="lazy" onerror="imgFallback(this,'RH')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>APP RRHH</h3>
          <p>Evaluación de talento con IA y metodología científica.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_ACCESOS', 'Control de Accesos')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-accesos.jpg" alt="Control de Accesos" loading="lazy" onerror="imgFallback(this,'CA')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>Control de Accesos</h3>
          <p>Control de accesos inteligente con RFID, biometría y QR.</p>
        </div>
      </div>
      <div class="video-card" data-category="producto" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_WEB', 'Desarrollo Web')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-web.jpg" alt="Desarrollo Web" loading="lazy" onerror="imgFallback(this,'DW')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Producto</span>
          <h3>Desarrollo Web</h3>
          <p>Páginas web corporativas y tiendas online a medida.</p>
        </div>
      </div>
      <div class="video-card" data-category="solucion" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_INDUSTRIAL', 'Industrial')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-industrial.jpg" alt="Industrial" loading="lazy" onerror="imgFallback(this,'IND')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Solución</span>
          <h3>Industrial</h3>
          <p>Solución para la gestión industrial y optimización de procesos productivos.</p>
        </div>
      </div>
      <div class="video-card" data-category="solucion" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_RETAIL', 'Retail')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-retail.jpg" alt="Retail" loading="lazy" onerror="imgFallback(this,'RET')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Solución</span>
          <h3>Retail</h3>
          <p>Gestión comercial inteligente para tiendas y canales online.</p>
        </div>
      </div>
      <div class="video-card" data-category="solucion" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_SERVICIOS', 'Servicios Profesionales')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-servicios.jpg" alt="Servicios Profesionales" loading="lazy" onerror="imgFallback(this,'SP')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Solución</span>
          <h3>Servicios Profesionales</h3>
          <p>Control de proyectos, facturación y rentabilidad para consultoras.</p>
        </div>
      </div>
      <div class="video-card" data-category="solucion" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_INMOBILIARIO', 'Inmobiliario')">
        <div class="video-card-thumb">
          <img src="/assets/images/thumbnails/thumb-inmobiliario.jpg" alt="Inmobiliario" loading="lazy" onerror="imgFallback(this,'INM')">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
        <div class="video-card-body">
          <span class="video-card-tag">Solución</span>
          <h3>Inmobiliario</h3>
          <p>Centraliza activos, inversores y colaboradores del sector inmobiliario.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function filterVideos(category) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.video-card').forEach(card => {
    const cats = card.dataset.category || '';
    card.style.display = (!category || category === 'all' || cats.split(',').includes(category)) ? 'block' : 'none';
  });
}
</script>

  <Footer slot="footer" />
</BaseLayout>
