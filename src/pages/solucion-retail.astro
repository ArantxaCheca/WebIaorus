---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'IAORUS Retail - Gestión Comercial Inteligente';
const description = 'Sistema de gestión comercial que unifica tiendas, almacén y canales online con inteligencia de negocio.';
const currentPage = '/solucion-retail';
const productKey = 'retail';
const productTag = 'Retail';
const productTitle = 'IAORUS Retail';
const productDesc = 'Impulsa tus ventas con datos inteligentes. Unifica tiendas, almacén y canales online con inteligencia de negocio integrada.';
const videoUrl = 'https://www.youtube.com/embed/VIDEO_ID_RETAIL';
const thumb = 'thumb-retail';
const thumbFallback = 'RET';
const benefits = [
  { title: 'Stock en tiempo real', desc: 'Sincronizado en todos tus canales de venta' },
  { title: 'Predicción de demanda', desc: 'Anticipa qué productos se venderán más' },
  { title: 'Ventas omnicanal', desc: 'Tienda física y online unificadas en una plataforma' },
  { title: 'Fidelización inteligente', desc: 'Ofertas personalizadas para cada cliente' }
];
const steps = [
  { number: '1', title: 'Unificamos canales', description: 'Conectamos tiendas, almacén y e-commerce' },
  { number: '2', title: 'Analizamos datos', description: 'El sistema aprende patrones de compra y comportamiento' },
  { number: '3', title: 'Optimizamos ventas', description: 'Decisiones basadas en datos para impulsar resultados' }
];
const demoHref = `/demo?producto=${productKey}`;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag" style="background:rgba(244,121,32,0.2);border-color:rgba(244,121,32,0.3);">Solución / {productTag}</span>
          <h1>{productTitle}</h1>
          <p>{productDesc}</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href={demoHref} class="btn btn-demo btn-lg">Solicitar demo {productTag} →</a>
            <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick={`openVideo('${videoUrl}', '${productTitle}')`}>
          <img src={`/assets/images/thumbnails/${thumb}.jpg`} alt={productTitle} onerror={`imgFallback(this,'${thumbFallback}')`}>
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2>¿Qué consigues con {productTitle}?</h2>
      </div>
      <div class="landing-benefits">
        {benefits.map(b => (
          <div class="landing-benefit">
            <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>Implementación en 3 pasos</h2>
      </div>
      <div class="landing-steps">
        {steps.map(s => (
          <div class="landing-step">
            <div class="landing-step-num">{s.number}</div>
            <h4>{s.title}</h4>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title="Transforma tu retail con datos inteligentes"
    subtitle={`Descubre cómo ${productTitle} puede ayudarte a unificar canales y aumentar tus ventas.`}
    ctaPrimary={{ text: `Solicitar demo ${productTag} →`, href: demoHref }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
    variant="landing-cta-section"
  />

  <Footer slot="footer" />
</BaseLayout>
