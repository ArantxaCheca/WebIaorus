---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'IAORUS Retail - Gestión Comercial Inteligente';
const description = 'Sistema de gestión comercial que unifica tiendas, almacén y canales online con inteligencia de negocio.';
const currentPage = '/solucion-retail';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
  <div class="video-hero-bg"></div>
  <div class="container">
    <div class="video-hero-content">
      <div class="video-hero-text">
        <span class="hero-tag" style="background:rgba(244,121,32,0.2);border-color:rgba(244,121,32,0.3);">Solución / Retail</span>
        <h1>IAORUS Retail</h1>
        <p>Impulsa tus ventas con datos inteligentes. Unifica tiendas, almacén y canales online con inteligencia de negocio integrada.</p>
        <div class="hero-actions" style="justify-content:flex-start;">
          <a href="/demo?producto=retail" class="btn btn-demo btn-lg">Solicitar demo Retail →</a>
          <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
        </div>
      </div>
      <div class="video-thumb-wrapper" onclick="openVideo('https://www.youtube.com/embed/VIDEO_ID_RETAIL', 'IAORUS Retail')">
        <img src="/assets/images/thumbnails/thumb-retail.jpg" alt="IAORUS Retail" onerror="imgFallback(this,'RET')">
        <div class="video-thumb-overlay">
          <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-title">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
      <h2>¿Qué consigues con IAORUS Retail?</h2>
    </div>
    <div class="landing-benefits">
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Stock en tiempo real</h4>
        <p>Sincronizado en todos tus canales de venta</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Predicción de demanda</h4>
        <p>Anticipa qué productos se venderán más</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Ventas omnicanal</h4>
        <p>Tienda física y online unificadas en una plataforma</p>
      </div>
      <div class="landing-benefit">
        <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h4>Fidelización inteligente</h4>
        <p>Ofertas personalizadas para cada cliente</p>
      </div>
    </div>
  </div>
</section>

<section class="bg-gray">
  <div class="container">
    <div class="section-title">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
      <h2>Implementación en 3 pasos</h2>
    </div>
    <div class="landing-steps">
      <div class="landing-step">
        <div class="landing-step-num">1</div>
        <h4>Unificamos canales</h4>
        <p>Conectamos tiendas, almacén y e-commerce</p>
      </div>
      <div class="landing-step">
        <div class="landing-step-num">2</div>
        <h4>Analizamos datos</h4>
        <p>El sistema aprende patrones de compra y comportamiento</p>
      </div>
      <div class="landing-step">
        <div class="landing-step-num">3</div>
        <h4>Optimizamos ventas</h4>
        <p>Decisiones basadas en datos para impulsar resultados</p>
      </div>
    </div>
  </div>
</section>

<section class="landing-cta-section">
  <div class="container">
    <h2>Transforma tu retail con datos inteligentes</h2>
    <p>Descubre cómo IAORUS Retail puede ayudarte a unificar canales y aumentar tus ventas.</p>
    <div class="landing-cta-actions">
      <a href="/demo?producto=retail" class="btn btn-demo btn-lg">Solicitar demo Retail →</a>
      <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
    </div>
  </div>
</section>

  <Footer slot="footer" />
</BaseLayout>
