---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import CtaBlock from '../components/CtaBlock.astro';
import StepsGrid from '../components/StepsGrid.astro';

const title = 'Productos - IAORUS';
const description = 'Productos IAORUS: ERP, BP360, Gest-IA, IATask, APP RRHH, Control de Accesos y Desarrollo Web. Soluciones inteligentes para tu empresa.';
const currentPage = '/productos';

const products = [
  { id: 'erp', title: 'IAORUS ERP', description: 'El centro de operaciones de tu empresa. Gestiona compras, ventas, almacén, finanzas, RRHH, proyectos y CRM desde un único panel. Todo integrado, todo en tiempo real.', tags: ['Gestión empresarial', 'ERP', 'CRM', 'Integración'], icon: 'erp' },
  { id: 'bp360', title: 'IAORUS BP360', description: 'La plataforma inteligente para el sector inmobiliario. Centraliza activos, inversores, colaboradores y operaciones. Con web colaborativa y dashboards de IA.', tags: ['Inmobiliario', 'IA', 'Inversiones'], icon: 'bp360' },
  { id: 'gestia', title: 'Gest-IA', description: 'Olvídate de buscar documentos perdidos. Gest-IA organiza, clasifica y encuentra cualquier expediente en segundos. Con IA que aprende de tu forma de trabajar.', tags: ['Documentos', 'IA', 'Expedientes'], icon: 'gestia' },
  { id: 'iatask', title: 'IATask', description: 'Controla la producción, las tareas y la asistencia de tu equipo. Planifica, mide y mejora la eficiencia operativa desde una plataforma unificada.', tags: ['Producción', 'Asistencia', 'Tiempos'], icon: 'iatask' },
  { id: 'apprrhh', title: 'APP RRHH', description: 'Encuentra y retén el mejor talento. Tests, evaluaciones e informes con inteligencia artificial para tomar decisiones informadas sobre tu equipo.', tags: ['RRHH', 'Talento', 'Evaluación'], icon: 'rrhh' },
  { id: 'accesos', title: 'Control de Accesos', description: 'Protege tus instalaciones con control de accesos inteligente. RFID, biometría y QR integrados con el ERP. Gestión centralizada desde un panel.', tags: ['Seguridad', 'Accesos', 'RFID'], icon: 'accesos' },
  { id: 'web', title: 'Desarrollo Web', description: 'Tu presencia online profesional. Páginas web corporativas y tiendas online diseñadas para convertir visitantes en clientes.', tags: ['Web', 'E-commerce', 'Diseño'], icon: 'web' }
];
const problems = [
  { title: 'Procesos manuales que ralentizan tu operativa', description: 'Automatiza tareas repetitivas y libera a tu equipo para lo que importa.' },
  { title: 'Sistemas que no se comunican entre sí', description: 'Centraliza toda tu operación en una sola plataforma integrada.' },
  { title: 'Falta de visibilidad en tiempo real', description: 'Toma decisiones informadas con datos actualizados al instante.' },
  { title: 'Costes elevados de desarrollo a medida', description: 'Configura sin programar. IAORUS se adapta sin necesidad de grandes inversiones.' }
];
const steps = [
  { number: '1', title: 'Se adapta a ti', description: 'Configuramos la plataforma según tus procesos, sin que tengas que cambiar tu forma de trabajar.' },
  { number: '2', title: 'Aprende de tu negocio', description: 'El sistema analiza tu operativa diaria para identificar patrones y proponer mejoras.' },
  { number: '3', title: 'Automatiza y mejora', description: 'Reduce tareas manuales, minimiza errores y acelera la toma de decisiones.' }
];
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="parallax-hero" style="background-image:url('/assets/images/pexels-kampus-8428091.jpg');">
    <div class="container">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Productos</span>
      <h1>Soluciones para cada necesidad</h1>
      <p>Cada producto resuelve problemas reales de negocio. Todos funcionan juntos o por separado.</p>
      <a href="/demo" class="btn btn-demo">Solicitar demo →</a>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title" style="margin-bottom:32px;">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Problemas que resolvemos</span>
        <h2>¿Tu negocio enfrenta estos retos?</h2>
        <p>Cada producto de IAORUS está diseñado para resolver un problema específico.</p>
      </div>
      <div class="problems-grid" style="margin-bottom:56px;">
        {problems.map(p => (
          <div class="problem-card">
            <h4>{p.title}</h4>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
      <ProductsGrid products={products} showSectionHeader={false} />
    </div>
  </section>

  <CtaBlock
    variant="inline"
    title="¿No sabes por dónde empezar?"
    subtitle="Te ayudamos a elegir la combinación de productos ideal para tu empresa."
    ctaPrimary={{ text: 'Hablar con un especialista →', href: '/demo' }}
  />

  <StepsGrid
    tag="Funcionalidad"
    title="Cómo funciona IAORUS"
    subtitle="Una plataforma que aprende de tu negocio para hacerlo más eficiente cada día."
    steps={steps}
    bgGray
  />

  <CtaBlock
    variant="floating"
    title="¿Necesitas ayuda para elegir?"
    ctaPrimary={{ text: 'Solicitar demo →', href: '/demo' }}
    ctaSecondary={{ text: 'Llamada', href: '/contacto' }}
  />

  <Footer slot="footer" />
</BaseLayout>
