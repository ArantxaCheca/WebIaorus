---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import CtaBlock from '../components/CtaBlock.astro';
import StepsGrid from '../components/StepsGrid.astro';

const title = 'Productos - IAORUS';
const description = 'Productos IAORUS: ERP, BP360, Gest-IA, IATask, APP RRHH, Control de Accesos y Desarrollo Web. Soluciones inteligentes para tu empresa.';
const currentPage = '/productos';

const products = [
  { id: 'erp', title: 'IAORUS ERP', description: 'Gestiona ventas, compras, clientes, finanzas y operaciones desde una única plataforma.', tags: ['ERP', 'CRM', 'Finanzas', 'Operaciones'], icon: 'erp' },
  { id: 'bp360', title: 'IAORUS BP360', description: 'Planifica objetivos, controla indicadores y toma mejores decisiones con una visión global del negocio.', tags: ['Estrategia', 'KPIs', 'Dirección', 'IA'], icon: 'bp360' },
  { id: 'gestia', title: 'Gest-IA', description: 'Organiza documentos, expedientes y procesos internos de forma más ágil y centralizada.', tags: ['Documentación', 'IA', 'Expedientes'], icon: 'gestia' },
  { id: 'iatask', title: 'IATask', description: 'Coordina tareas, producción, incidencias y mantenimiento desde un único entorno operativo.', tags: ['Producción', 'Tareas', 'Incidencias'], icon: 'iatask' },
  { id: 'apprrhh', title: 'APP RRHH', description: 'Centraliza la gestión de empleados, vacaciones, talento y evaluaciones internas.', tags: ['RRHH', 'Talento', 'Evaluación'], icon: 'rrhh' },
  { id: 'accesos', title: 'Control de Accesos', description: 'Gestiona presencia, accesos y seguridad de forma sencilla y conectada.', tags: ['Seguridad', 'Presencia', 'RFID'], icon: 'accesos' },
  { id: 'web', title: 'Desarrollo Web', description: 'Diseñamos webs, ecommerce y soluciones digitales adaptadas a los objetivos de tu negocio.', tags: ['Web', 'Ecommerce', 'Diseño'], icon: 'web' }
];
const problems = [
  { title: 'Procesos manuales que frenan tu negocio', description: 'Automatiza tareas repetitivas y libera a tu equipo para lo que realmente importa.' },
  { title: 'Sistemas que no se comunican', description: 'Centraliza ventas, finanzas y operaciones en una sola plataforma integrada.' },
  { title: 'Falta de visibilidad en tiempo real', description: 'Toma decisiones informadas con datos actualizados al instante desde cualquier lugar.' },
  { title: 'Costes elevados de desarrollo a medida', description: 'Configura sin programar. IAORUS se adapta a tu negocio sin grandes inversiones.' }
];
const steps = [
  { number: '1', title: 'Se adapta a ti', description: 'Configuramos la plataforma según tus procesos, sin que tengas que cambiar tu forma de trabajar.' },
  { number: '2', title: 'Aprende de tu negocio', description: 'El sistema analiza tu operativa diaria para identificar patrones y proponer mejoras.' },
  { number: '3', title: 'Automatiza y mejora', description: 'Reduce tareas manuales, minimiza errores y acelera la toma de decisiones.' }
];
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="parallax-hero" style="background-image:url('/assets/images/pexels-kampus-8428091.jpg');">
    <div class="container">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Productos</span>
      <h1>Soluciones para cada necesidad</h1>
      <p>Cada producto resuelve problemas reales de negocio. Todos funcionan juntos o por separado.</p>
      <a href="/demo" class="btn btn-demo">Solicitar demo →</a>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title" style="margin-bottom:32px;">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Por qué IAORUS</span>
        <h2>¿Por qué las empresas eligen IAORUS?</h2>
        <p>Resolvemos los problemas que frenan el crecimiento de tu negocio.</p>
      </div>
      <div class="problems-grid" style="margin-bottom:56px;">
        {problems.map(p => (
          <div class="problem-card">
            <h4>{p.title}</h4>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
      <ProductsGrid products={products} showSectionHeader={false} highlightProductId="erp" />
    </div>
  </section>

  <CtaBlock
    variant="default"
    title="¿Qué solución necesita tu empresa?"
    subtitle="Te ayudamos a identificar la herramienta más adecuada según tus procesos, objetivos y nivel de digitalización."
    ctaPrimary={{ text: 'Solicitar Demo', href: '/demo' }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
  />

  <StepsGrid
    tag="Funcionalidad"
    title="Cómo funciona IAORUS"
    subtitle="Una plataforma que aprende de tu negocio para hacerlo más eficiente cada día."
    steps={steps}
    bgGray
  />

  <CtaBlock
    variant="floating"
    title="¿Necesitas ayuda para elegir?"
    ctaPrimary={{ text: 'Solicitar demo →', href: '/demo' }}
    ctaSecondary={{ text: 'Llamada', href: '/contacto' }}
  />

  <Footer slot="footer" />
</BaseLayout>
