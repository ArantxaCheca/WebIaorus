---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = 'Servicios - IAORUS';
const description = 'Servicios IAORUS: licencias SaaS, desarrollo a medida, consultoría, formación, outsourcing e implantación.';
const currentPage = '/servicios';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="parallax-hero" style="background-image: url('/assets/images/pexels-gustavo-fring-4872048.jpg');">
  <div class="parallax-overlay"></div>
  <div class="container parallax-content">
    <h1>Servicios</h1>
    <p>Más que un proveedor de software, somos tu partner estratégico en transformación digital.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-title">
      <span class="section-tag">Modelo de Negocio</span>
      <h2>Flexibilidad total para tu empresa</h2>
      <p>Elige el modelo que mejor se adapte a tus necesidades: desde suscripción SaaS hasta desarrollo completo a medida.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:24px;margin-bottom:48px;">
      <div style="background:var(--white);border-radius:var(--radius);padding:32px;box-shadow:var(--shadow);border:2px solid var(--blue);text-align:center;">
        <div style="margin-bottom:12px;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
        </div>
        <h3 style="color:var(--blue-dark);">Licencia SaaS</h3>
        <div style="font-size:2rem;font-weight:800;color:var(--blue);margin:16px 0;">25.000 - 80.000€</div>
        <p style="font-size:0.9rem;color:var(--gray);">Por año, según módulos y usuarios</p>
        <ul style="list-style:none;text-align:left;margin:16px 0;font-size:0.9rem;">
          <li style="padding:6px 0;">✓ Plataforma completa con IA</li>
          <li style="padding:6px 0;">✓ Soporte y mantenimiento incluido</li>
          <li style="padding:6px 0;">✓ Actualizaciones automáticas</li>
          <li style="padding:6px 0;">✓ Actualizaciones IA periódicas</li>
        </ul>
        <a href="/demo" class="btn btn-demo">Solicitar Demo</a>
      </div>
      <div style="background:var(--white);border-radius:var(--radius);padding:32px;box-shadow:var(--shadow);text-align:center;">
        <div style="margin-bottom:12px;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 style="color:var(--blue-dark);">Desarrollo a Medida</h3>
        <div style="font-size:2rem;font-weight:800;color:var(--blue);margin:16px 0;">45.000 - 150.000€</div>
        <p style="font-size:0.9rem;color:var(--gray);">Por proyecto, alcance personalizado</p>
        <ul style="list-style:none;text-align:left;margin:16px 0;font-size:0.9rem;">
          <li style="padding:6px 0;">✓ Software 100% personalizado</li>
          <li style="padding:6px 0;">✓ Metodología ágil y rápida</li>
          <li style="padding:6px 0;">✓ Integración con sistemas existentes</li>
          <li style="padding:6px 0;">✓ Formación y soporte premium</li>
        </ul>
        <a href="/contacto" class="btn btn-orange">Solicitar Presupuesto</a>
      </div>
    </div>

    <div class="section-title" style="margin-top:64px;">
      <span class="section-tag">Servicios Complementarios</span>
      <h2>Acompañamiento completo</h2>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
        </div>
        <h3>Consultoría Tecnológica</h3>
        <p>Diagnóstico de madurez digital, análisis de procesos, identificación de ineficiencias y hoja de ruta tecnológica personalizada.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <h3>Formación</h3>
        <p>Capacitación del equipo en la plataforma IAORUS y en fundamentos de transformación digital. Presencial u online.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <h3>Implantación y Onboarding</h3>
        <p>Acompañamiento completo en la implantación: configuración, migración de datos, pruebas y puesta en producción.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        </div>
        <h3>Outsourcing de Negocio</h3>
        <p>Externaliza procesos con plataforma tecnológica a medida y personal dedicado. Aumenta tu capacidad sin crecer en estructura.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Soporte y Mantenimiento</h3>
        <p>Soporte técnico especializado, mantenimiento correctivo y evolutivo, actualizaciones periódicas de IA y monitorización 24/7.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h3>Marketplace de Módulos</h3>
        <p>Accede a extensiones y plugins desarrollados por terceros para ampliar funcionalidades de tu plataforma IAORUS.</p>
      </div>
    </div>
  </div>
</section>

<section class="split-grid">
  <div class="container split-grid-inner">
    <div class="split-grid-content">
      <span class="section-tag">Nuestro Equipo</span>
      <h2>Profesionales comprometidos con tu éxito</h2>
      <p>Contamos con un equipo multidisciplinar de expertos en tecnología, transformación digital e inteligencia artificial, listos para afrontar los retos más exigentes de tu negocio.</p>
      <ul style="list-style:none;margin-top:16px;">
        <li style="padding:6px 0;">✓ Consultores senior con experiencia contrastada</li>
        <li style="padding:6px 0;">✓ Metodología ágil y orientada a resultados</li>
        <li style="padding:6px 0;">✓ Soporte continuo durante todo el ciclo de vida</li>
      </ul>
    </div>
    <div class="split-grid-image">
      <img src="/assets/images/pexels-kampus-8353815.jpg" alt="Equipo profesional trabajando">
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>¿Qué servicio necesitas?</h2>
    <p>Cuéntanos tu proyecto y te recomendaremos el modelo más adecuado.</p>
    <div class="cta-actions">
      <a href="/demo" class="btn btn-demo">Solicitar Demo →</a>
      <a href="/contacto" class="btn btn-orange">Contactar</a>
    </div>
  </div>
</section>

  <Footer slot="footer" />
</BaseLayout>
