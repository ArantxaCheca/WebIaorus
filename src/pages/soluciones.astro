---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'Soluciones por Sector - IAORUS';
const description = 'Soluciones IAORUS adaptadas a cada sector: industrial, retail, servicios, inmobiliario y más. Software que se adapta a tu industria.';
const currentPage = '/soluciones';

const sectors = [
  {
    id: 'industrial', tag: 'Industrial', title: 'Automatiza tu planta y optimiza la producción',
    queEs: 'Sistema de gestión industrial que integra producción, trazabilidad y control de accesos en una sola plataforma inteligente.',
    paraQuien: 'Fábricas, plantas de producción y empresas logísticas de más de 20 empleados.',
    problema: 'Procesos lentos, falta de trazabilidad, errores de inventario y desconexión entre departamentos.',
    beneficios: ['Automatización de procesos productivos', 'Trazabilidad completa de materiales y lotes', 'Reducción de errores y mermas en producción', 'Control de acceso y tiempos integrado', 'Escalabilidad para crecimiento de planta'],
    comoFunciona: 'El sistema se conecta con tu operativa diaria y aprende de ella. Automatiza tareas repetitivas, detecta cuellos de botella y te alerta antes de que surjan problemas. Todo desde un panel central que muestra el estado de tu planta en tiempo real.',
    href: '/solucion-industrial'
  },
  {
    id: 'retail', tag: 'Retail', title: 'Impulsa tus ventas con datos inteligentes',
    queEs: 'Sistema de gestión comercial que unifica tiendas, almacén y canales online con inteligencia de negocio integrada.',
    paraQuien: 'Cadenas retail, franquicias, tiendas especializadas y comercios multicanal.',
    problema: 'Stock descontrolado, ventas offline y online desconectadas, promociones difíciles de gestionar.',
    beneficios: ['Stock en tiempo real en todos los canales', 'Predicción de demanda para optimizar compras', 'Incremento de ventas con recomendaciones', 'Fidelización con ofertas personalizadas'],
    comoFunciona: 'Centraliza todos tus canales y analiza el comportamiento de tus clientes. El sistema aprende qué se vende más, cuándo y a quién, para ayudarte a tomar mejores decisiones comerciales.',
    href: '/solucion-retail'
  },
  {
    id: 'servicios', tag: 'Servicios Profesionales', title: 'Controla proyectos y haz crecer tu consultora',
    queEs: 'Sistema de gestión para empresas de servicios que necesitan controlar proyectos, facturar correctamente y medir su rentabilidad.',
    paraQuien: 'Consultoras, agencias, despachos profesionales, ingenierías y servicios B2B.',
    problema: 'Proyectos descontrolados, facturación retrasada y procesos administrativos que consumen tiempo.',
    beneficios: ['Control de horas y rentabilidad por proyecto', 'Facturación automatizada sin errores', 'Reporting inteligente para decisiones'],
    comoFunciona: '',
    href: '/solucion-servicios'
  },
  {
    id: 'inmobiliario', tag: 'Inmobiliario', title: 'Profesionaliza tu negocio inmobiliario',
    queEs: 'Plataforma que centraliza activos, inversores y colaboradores del sector inmobiliario en un solo entorno digital.',
    paraQuien: 'Inmobiliarias, gestoras de activos, promotoras e inversores.',
    problema: 'Información dispersa, colaboración desorganizada y procesos comerciales lentos.',
    beneficios: ['Activos y documentación centralizados', 'Red privada de colaboradores', 'Gestión profesional de inversores'],
    comoFunciona: '',
    href: '/solucion-inmobiliario'
  }
];
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="parallax-hero" style="background-image:url('/assets/images/pexels-kampus-8353820.jpg');">
    <div class="container">
      <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Sectores</span>
      <h1>Soluciones para tu industria</h1>
      <p>Cada sector tiene sus propios desafíos. IAORUS se adapta a ellos para ayudarte a crecer.</p>
      <a href="/demo" class="btn btn-demo">Solicitar demo →</a>
    </div>
  </section>

  <section>
    <div class="container">
      {sectors.map((s, idx) => (
        <div>
          <div class="section-title">
            <span class="section-tag">{s.tag}</span>
            <h2>{s.title}</h2>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;margin-bottom:48px;">
            <div>
              <h4 style="color:var(--orange);margin-bottom:8px;">¿Qué es?</h4>
              <p>{s.queEs}</p>
              <h4 style="color:var(--orange);margin-top:24px;margin-bottom:8px;">¿Para quién?</h4>
              <p>{s.paraQuien}</p>
              <h4 style="color:var(--orange);margin-top:24px;margin-bottom:8px;">¿Qué problema resuelve?</h4>
              <p>{s.problema}</p>
              <a href={s.href} class="btn btn-orange" style="margin-top:16px;">Ver solución {s.tag.toLowerCase()} →</a>
            </div>
            <div>
              <h4 style="color:var(--orange);margin-bottom:12px;">Beneficios</h4>
              <div style="display:grid;gap:12px;">
                {s.beneficios.map(b => (
                  <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--gray-bg);border-radius:8px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F47920" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-size:0.9rem;">{b}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          {s.comoFunciona && (
            <div style="background:var(--gray-bg);border-radius:12px;padding:24px;margin-bottom:64px;">
              <h4 style="color:var(--orange);margin-bottom:8px;">¿Cómo funciona?</h4>
              <p style="font-size:0.95rem;margin-bottom:0;">{s.comoFunciona}</p>
            </div>
          )}
          {!s.comoFunciona && <div style="margin-bottom:64px;"></div>}
        </div>
      ))}
    </div>
  </section>

  <CtaBlock
    title="¿No encuentras tu sector?"
    subtitle="IAORUS se adapta a cualquier industria. Cuéntanos tu caso y te propondremos la mejor solución."
    ctaPrimary={{ text: 'Solicitar demo →', href: '/demo' }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
  />

  <CtaBlock
    variant="floating"
    title="¿Hablamos de tu sector?"
    ctaPrimary={{ text: 'Solicitar demo →', href: '/demo' }}
    ctaSecondary={{ text: 'Llamada', href: '/contacto' }}
  />

  <Footer slot="footer" />
</BaseLayout>
