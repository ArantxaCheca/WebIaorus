---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBlock from '../components/CtaBlock.astro';

const title = 'IAORUS Servicios Profesionales';
const description = 'Sistema de gestión para empresas de servicios que necesitan controlar proyectos, facturar y medir rentabilidad.';
const currentPage = '/solucion-servicios';
const productKey = 'servicios';
const productTag = 'Servicios';
const productTitle = 'IAORUS Servicios Profesionales';
const productDesc = 'Controla proyectos y haz crecer tu consultora. Gestiona proyectos, facturación y rentabilidad desde una plataforma.';
const videoUrl = 'https://www.youtube.com/embed/VIDEO_ID_SERVICIOS';
const thumb = 'thumb-servicios';
const thumbFallback = 'SP';
const benefits = [
  { title: 'Control de proyectos', desc: 'Horas, recursos y rentabilidad en tiempo real' },
  { title: 'Facturación automatizada', desc: 'Olvídate de facturas atrasadas y errores' },
  { title: 'Reporting inteligente', desc: 'Toma decisiones con datos precisos' },
  { title: 'Eficiencia administrativa', desc: 'Reduce la carga burocrática de tu equipo' }
];
const steps = [
  { number: '1', title: 'Configuramos tu estructura', description: 'Proyectos, clientes y equipos listos en la plataforma' },
  { number: '2', title: 'Automatizamos procesos', description: 'Facturación, reporting y control horario sin esfuerzo' },
  { number: '3', title: 'Haces crecer tu negocio', description: 'Dedica más tiempo a lo que realmente importa' }
];
const demoHref = `/demo?producto=${productKey}`;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="video-hero">
    <div class="video-hero-bg"></div>
    <div class="container">
      <div class="video-hero-content">
        <div class="video-hero-text">
          <span class="hero-tag" style="background:rgba(244,121,32,0.2);border-color:rgba(244,121,32,0.3);">Solución / {productTag}</span>
          <h1>{productTitle}</h1>
          <p>{productDesc}</p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href={demoHref} class="btn btn-demo btn-lg">Solicitar demo {productTag} →</a>
            <a href="/contacto" class="btn btn-outline-orange btn-lg">Hablar con un especialista</a>
          </div>
        </div>
        <div class="video-thumb-wrapper" onclick={`openVideo('${videoUrl}', '${productTitle}')`}>
          <img src={`/assets/images/thumbnails/${thumb}.jpg`} alt={productTitle} onerror={`imgFallback(this,'${thumbFallback}')`}>
          <div class="video-thumb-overlay">
            <div class="play-btn"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Beneficios</span>
        <h2>¿Qué consigues con {productTitle}?</h2>
      </div>
      <div class="landing-benefits">
        {benefits.map(b => (
          <div class="landing-benefit">
            <div class="landing-benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="section-title">
        <span class="section-tag" style="background:rgba(244,121,32,0.15);color:var(--orange);">Cómo funciona</span>
        <h2>Implementación en 3 pasos</h2>
      </div>
      <div class="landing-steps">
        {steps.map(s => (
          <div class="landing-step">
            <div class="landing-step-num">{s.number}</div>
            <h4>{s.title}</h4>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title="Transforma tu consultora con datos inteligentes"
    subtitle={`Descubre cómo ${productTitle} puede ayudarte a controlar proyectos y escalar tu negocio.`}
    ctaPrimary={{ text: `Solicitar demo ${productTag} →`, href: demoHref }}
    ctaSecondary={{ text: 'Hablar con un especialista', href: '/contacto' }}
    variant="landing-cta-section"
  />

  <Footer slot="footer" />
</BaseLayout>
