---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contacto - IAORUS';
const description = 'Contacta con IAORUS para más información sobre nuestras soluciones de software inteligente.';
const currentPage = '/contacto';
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Header slot="header" currentPage={currentPage} />

  <section class="page-header">
    <div class="container">
      <h1>Contacto</h1>
      <p>Estamos aquí para ayudarte. Cuéntanos cómo podemos colaborar.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="contact-grid">
        <div>
          <div class="contact-image">
            <img src="/assets/images/pexels-gustavo-fring-4872048.jpg" alt="Profesional con tablet" style="width:100%;border-radius:var(--radius);margin-bottom:24px;">
          </div>
          <h3 style="color:var(--blue-dark);margin-bottom:24px;">Información de contacto</h3>
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h4>Dirección</h4>
              <p>Madrid, España</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <h4>Email</h4>
              <p>info@iaorus.com</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <h4>Web</h4>
              <p>iaorus.com</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <h4>Horario</h4>
              <p>Lun–Vie: 9:00 – 18:00</p>
            </div>
          </div>
          <div style="margin-top:32px;padding:24px;background:var(--gray-bg);border-radius:var(--radius);">
            <h4 style="color:var(--blue-dark);margin-bottom:8px;">¿Prefieres una demo?</h4>
            <p style="font-size:0.9rem;margin-bottom:16px;">Solicita una sesión personalizada y descubre cómo IAORUS puede transformar tu negocio.</p>
            <a href="/demo" class="btn btn-demo">Solicitar Demo →</a>
          </div>
        </div>
        <div>
          <h3 style="color:var(--blue-dark);margin-bottom:24px;">Envíanos un mensaje</h3>
          <form id="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="contact-nombre">Nombre *</label>
                <input type="text" id="contact-nombre" name="nombre" required placeholder="Tu nombre">
              </div>
              <div class="form-group">
                <label for="contact-email">Email *</label>
                <input type="email" id="contact-email" name="email" required placeholder="tu@email.com">
              </div>
            </div>
            <div class="form-group">
              <label for="contact-asunto">Asunto</label>
              <select id="contact-asunto" name="asunto">
                <option value="">Selecciona un asunto</option>
                <option value="informacion">Solicitar información</option>
                <option value="comercial">Consulta comercial</option>
                <option value="soporte">Soporte técnico</option>
                <option value="partner">Quiero ser partner</option>
                <option value="colaboracion">Propuesta de colaboración</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-mensaje">Mensaje *</label>
              <textarea id="contact-mensaje" name="mensaje" required placeholder="Cuéntanos en qué podemos ayudarte..."></textarea>
            </div>
            <button type="submit" class="btn btn-demo" style="width:100%;justify-content:center;padding:14px;">Enviar mensaje →</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
